{% assign reaction_emojis = '👍,❤️,🎉,😮,🚀' | split: ',' %}

<div class="post-reactions">
  <span class="reactions-label"><i class="fa-solid fa-face-smile fa-sm"></i> Reactions</span>
  {% for emoji in reaction_emojis %}
    <button class="reaction-btn" data-emoji="{{ emoji }}" title="{{ emoji }}">
      <span class="reaction-emoji">{{ emoji }}</span>
      <span class="reaction-count">–</span>
    </button>
  {% endfor %}
</div>
