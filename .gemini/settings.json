{
  "context": {
    "fileName": [
      "AGENTS.md",
      ".github/copilot-instructions.md",
      ".github/agents/customize.agent.md",
      ".github/agents/docs.agent.md",
      ".github/instructions/**/*.md",
      "CUSTOMIZE.md",
      "INSTALL.md",
      "TROUBLESHOOTING.md",
      "QUICKSTART.md"
    ]
  },
  "mcpServers": {
    "code-review-graph": {
      "command": "uvx",
      "args": ["code-review-graph", "serve"],
      "cwd": "/Users/avinesh/workspace/avineshpolisetty"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/crg-session-start.sh",
            "name": "code-review-graph status",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/crg-update.sh",
            "name": "code-review-graph update",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
